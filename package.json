{
  "name": "sentinel-ai---cyber-monitor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:unit",
    "test:unit": "node -e \"require('fs').mkdirSync('reports',{recursive:true})\" && vitest run --reporter=default --reporter=junit --outputFile=reports/vitest-junit.xml --coverage --coverage.reporter=text --coverage.reporter=lcov --coverage.reporter=cobertura --coverage.reportsDirectory=reports/vitest-coverage",
    "test:unit:watch": "vitest",
    "test:e2e": "node -e \"require('fs').mkdirSync('reports',{recursive:true})\" && playwright test"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@google/genai": "^1.30.0",
    "axios": "^1.13.2",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.4.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.0.6",
    "autoprefixer": "^10.4.23",
    "axios-mock-adapter": "^2.1.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.6"
  }
}
